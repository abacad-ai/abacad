<?xml version="1.0" encoding="utf-8"?>
<!--
  abacad launcher mark: a lowercase "a" (round bowl + stem) with a coral status
  dot in the counter. Pure vector => infinitely sharp at every density.
  Drawn on the 108x108 adaptive canvas; the glyph sits inside the ~66dp safe
  zone so no OEM mask (circle/squircle/rounded-square) clips it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- bowl (blue disc) -->
    <path
        android:fillColor="#13A7F5"
        android:pathData="M27.6,53.67 a24.75,24.75 0 1,0 49.5,0 a24.75,24.75 0 1,0 -49.5,0 Z" />
    <!-- stem (blue vertical pill) -->
    <path
        android:fillColor="#13A7F5"
        android:pathData="M75.78,29.58 a4.62,4.62 0 0 1 4.62,4.62 v38.94 a4.62,4.62 0 0 1 -4.62,4.62 a4.62,4.62 0 0 1 -4.62,-4.62 v-38.94 a4.62,4.62 0 0 1 4.62,-4.62 Z" />
    <!-- counter (white) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38.82,53.67 a13.53,13.53 0 1,0 27.06,0 a13.53,13.53 0 1,0 -27.06,0 Z" />
    <!-- accent dot (coral) -->
    <path
        android:fillColor="#FD605E"
        android:pathData="M44.76,53.67 a7.59,7.59 0 1,0 15.18,0 a7.59,7.59 0 1,0 -15.18,0 Z" />
</vector>
