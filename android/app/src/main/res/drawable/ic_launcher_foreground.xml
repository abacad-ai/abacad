<?xml version="1.0" encoding="utf-8"?>
<!--
  abacad launcher mark: four connected dots (one hub -> three devices) that read as
  an "A"; the green hub is the single "alive" accent. Drawn in a 512 viewport scaled
  onto the 108dp adaptive canvas, sized so the whole graph sits inside the ~66% safe
  circle => no OEM mask (circle / squircle / teardrop) clips a node.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- edges: hub -> three device nodes (silver, half strength) -->
    <path
        android:strokeColor="#D8DADE"
        android:strokeWidth="11"
        android:strokeAlpha="0.5"
        android:strokeLineCap="round"
        android:pathData="M256,273 L256,168 M256,273 L149,344 M256,273 L363,344" />
    <!-- device nodes (silver) -->
    <path android:fillColor="#D8DADE"
        android:pathData="M234,168 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
    <path android:fillColor="#D8DADE"
        android:pathData="M127,344 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
    <path android:fillColor="#D8DADE"
        android:pathData="M341,344 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
    <!-- hub = live (green) -->
    <path android:fillColor="#30D158"
        android:pathData="M230,273 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0 Z" />
</vector>
