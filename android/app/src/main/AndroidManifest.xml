<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Accessibility itself needs NO manifest permission — it's the one-time
      toggle, and it's what unlocks tree + tap + screenshot. INTERNET is only to
      reach the abacad server. Cleartext is disabled (see network_security_config);
      the server must be reached over wss:// (TLS).
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- WAKE_LOCK: brief CPU hold across a `wake` so the process survives from
         packet-arrival through launching the waker. SYSTEM_ALERT_WINDOW: grants the
         background-activity-launch exemption some OEM ROMs require to start the waker
         from the (background) accessibility service. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Foreground service: run the accessibility service at foreground priority
         while connected, so OEM battery managers (esp. Samsung One UI) don't freeze
         the process the moment the screen goes dark and kill the idle socket.
         dataSync = "keep device state synced with the server"; needs no extra
         prerequisite permission (unlike connectedDevice). POST_NOTIFICATIONS lets
         the ongoing notification actually show on Android 13+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- FOREGROUND_SERVICE_MEDIA_PROJECTION: screen_recording captures the display via
         MediaProjection, which (Android 14+) requires a running mediaProjection
         foreground service. The service carries the type only while recording. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Ask to be exempted from Doze/battery optimization so the held socket
         survives screen-off idle off-charger (the setup flow always promised this). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- CAMERA: only to scan the connection QR shown by the server dashboard. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Package visibility (Android 11+): so live view can detect + launch the
         droidVNC-NG companion (the real RFB server for the live channel). -->
    <queries>
        <package android:name="net.christianbeier.droidvnc_ng" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="abacad"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Abacad">
        <!-- DayNight DeviceDefault (themes.xml): follows the system appearance, like
             the dashboard and macOS agent; Theme.of(resources) supplies the matching
             dark or light palette from design/tokens.json. -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Camera QR scanner for the connection URL. Launched from MainActivity. -->
        <activity
            android:name=".ScanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Abacad.NoActionBar" />

        <service
            android:name=".AbacadAccessibilityService"
            android:exported="false"
            android:foregroundServiceType="dataSync|mediaProjection"
            android:label="abacad"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Invisible screen-recording consent shim: fires the system MediaProjection
             "Start recording?" dialog, then finishes. Launched only by our own service. -->
        <activity
            android:name=".ScreenRecordConsentActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Invisible waker: turns the screen on + dismisses a non-secure keyguard when a
             command arrives on a dark device. Launched only by our own service. -->
        <activity
            android:name=".WakerActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
    </application>
</manifest>
