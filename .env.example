# Copy to .env and fill in. .env is gitignored; this file is not — keep real
# secrets out of it.
#
# Loaded by the Go server at startup (see server/backend/internal/config).
# Anything already set in the real environment wins.
#
# This is local dev config only. Production has its own .env, shipped by the
# deploy script in the infra repo (deployment/xyz-sg-1/abacad.ai/) — changing
# values here does not affect abacad.ai.

# --- Sign in with Google -----------------------------------------------------
# From https://console.cloud.google.com/apis/credentials — an "OAuth 2.0 Client
# ID" of type "Web application". Both must be set or the button stays hidden.
ABACAD_GOOGLE_CLIENT_ID=
ABACAD_GOOGLE_CLIENT_SECRET=
# Optional. Derived from the incoming request when empty. Set it in production
# so the callback never depends on proxy X-Forwarded-* headers. Must match a
# redirect URI registered on the OAuth client, exactly.
# ABACAD_GOOGLE_REDIRECT_URL=https://abacad.ai/api/auth/google/callback

# --- Server ------------------------------------------------------------------
# ABACAD_ADDR=:8848
# ABACAD_DB=abacad.db
# ABACAD_BLOBS=abacad-blobs
# ABACAD_SCREENSHOTS=abacad-screenshots
# ABACAD_DOWNLOADS=abacad-downloads
# ABACAD_MAX_BLOB_BYTES=1073741824
# ABACAD_ACTIVITY_RETENTION_DAYS=90
# Data-minimization retention (0 = keep forever):
# ABACAD_BLOB_RETENTION_DAYS=7          # transferred files + screen recordings
# ABACAD_SCREENSHOT_RETENTION_HOURS=24  # cached per-device screenshots
# Devices auto-expire 24h after enrollment (fixed product behavior, not configurable);
# extend or "make permanent" per device to keep. This knob is only the retention window
# for the dormant rows left behind:
# ABACAD_DEVICE_DORMANT_DELETE_DAYS=7   # hard-delete a device this long after it expires (0 = keep)
# ABACAD_DEV_CORS=1

# --- SSH jump host (empty disables it) ---------------------------------------
# ABACAD_SSH_ADDR=:22,:443
# ABACAD_SSH_HOST_KEY=ssh_host_ed25519_key
# ABACAD_BASE_DOMAIN=abacad.ai
