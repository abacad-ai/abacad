<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Abacad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="abacad">

    <Grid Background="{ThemeResource CanvasBrush}">
        <ScrollViewer>
            <StackPanel Padding="20" Spacing="12">

                <!-- state header: dot + title/subtitle + Pause/Disconnect -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse x:Name="Dot" Width="12" Height="12" VerticalAlignment="Top" Margin="0,4,0,0" />
                    <StackPanel Width="230">
                        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" />
                        <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="{ThemeResource InkMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel x:Name="ControlButtons" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Button x:Name="PauseBtn" Content="Pause" Click="OnPause" />
                        <Button x:Name="DisconnectBtn" Content="Disconnect" Click="OnDisconnect" />
                    </StackPanel>
                </StackPanel>

                <!-- "screen being watched" / "recording" flags -->
                <StackPanel x:Name="Flags" Orientation="Horizontal" Spacing="8" />

                <!-- setup, shown while disconnected -->
                <StackPanel x:Name="SetupPanel" Spacing="6">
                    <TextBlock Text="Server URL" FontSize="12" Foreground="{ThemeResource InkMutedBrush}" />
                    <TextBox x:Name="UrlBox" PlaceholderText="wss://host/device?token=…" />
                    <Button x:Name="ConnectBtn" Content="Connect" Click="OnConnect" />
                </StackPanel>

                <!-- recent actions, shown while connected -->
                <StackPanel x:Name="ActionsPanel" Spacing="6">
                    <TextBlock Text="RECENT ACTIONS" FontSize="11" Foreground="{ThemeResource InkMutedBrush}" />
                    <Border Background="{ThemeResource SurfaceBrush}" CornerRadius="8" Padding="10">
                        <TextBlock x:Name="ActionsText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <TextBlock
                    FontSize="12" Foreground="{ThemeResource InkMutedBrush}" TextWrapping="Wrap"
                    Text="Once connected an agent can view and control this PC; Pause rejects commands without dropping the link, Disconnect drops it. Driving windows owned by an elevated (administrator) app requires running abacad as administrator too." />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
